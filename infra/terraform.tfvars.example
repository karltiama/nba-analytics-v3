# Copy to terraform.tfvars and set real values. Do not commit terraform.tfvars.
# Or pass via environment: export TF_VAR_aws_region=us-east-1

aws_region          = "us-east-1"
lambda_function_name = "nightly-bdl-updater"
lambda_timeout      = 300
lambda_memory_size  = 512

# Set to true to run the Lambda daily on schedule (e.g. 08:00 UTC).
enable_schedule = false
schedule_cron   = "cron(0 8 * * ? *)"

# Required for nightly-bdl-updater. Use real values in terraform.tfvars or TF_VAR_lambda_env.
lambda_env = {
  SUPABASE_DB_URL       = "postgresql://postgres.PROJECT:PASSWORD@REGION.pooler.supabase.com:6543/postgres"
  BALLDONTLIE_API_KEY   = "your_balldontlie_api_key"
  # Optional:
  # BALLDONTLIE_REQUEST_DELAY_MS = "200"
  # MAX_RETRIES                  = "3"
}

# -----------------------------------------------------------------------------
# Odds pre-game snapshot Lambda
# -----------------------------------------------------------------------------
odds_lambda_function_name = "odds-pre-game-snapshot"
odds_lambda_timeout        = 300
odds_lambda_memory_size   = 512
odds_enable_schedule      = true
# Single run (e.g. 09:00 ET) when odds_schedule_crons is not set:
# odds_schedule_cron = "cron(0 14 * * ? *)"
# Every 30 min 10am-12pm ET (UTC 15:00, 15:30, 16:00, 16:30, 17:00):
odds_schedule_crons = [
  "cron(0 15 * * ? *)",
  "cron(30 15 * * ? *)",
  "cron(0 16 * * ? *)",
  "cron(30 16 * * ? *)",
  "cron(0 17 * * ? *)",
]

# Required for odds-pre-game-snapshot. Use real values in terraform.tfvars.
odds_lambda_env = {
  SUPABASE_DB_URL     = "postgresql://postgres.PROJECT:PASSWORD@REGION.pooler.supabase.com:6543/postgres"
  BALLDONTLIE_API_KEY = "your_balldontlie_api_key"
  # Optional:
  # PREFERRED_VENDOR = "draftkings"
}

# -----------------------------------------------------------------------------
# Injuries snapshot Lambda
# -----------------------------------------------------------------------------
injuries_lambda_function_name = "injuries-snapshot"
injuries_lambda_timeout       = 120
injuries_lambda_memory_size   = 256
injuries_enable_schedule      = false
injuries_schedule_cron        = "cron(0 13,18,22 * * ? *)"

# Required for injuries-snapshot. Use real values in terraform.tfvars.
injuries_lambda_env = {
  SUPABASE_DB_URL     = "postgresql://postgres.PROJECT:PASSWORD@REGION.pooler.supabase.com:6543/postgres"
  BALLDONTLIE_API_KEY = "your_balldontlie_api_key"
}

# -----------------------------------------------------------------------------
# Player props ingestion Lambda (EventBridge Scheduler)
# Set player_props_enable_schedule = true so the Lambda runs and fills analytics.player_props_current.
# Without this, the player page sidebar has no props (empty "All stats" dropdown).
# -----------------------------------------------------------------------------
player_props_lambda_function_name = "nba-player-props-ingestion-lambda"
player_props_lambda_timeout       = 300
player_props_lambda_memory_size   = 512
player_props_enable_schedule      = true
player_props_schedule_expression  = "rate(30 minutes)"

# Optional: run only 10am-12pm ET every 30 min (UTC 15:00, 15:30, 16:00, 16:30, 17:00). When set, overrides rate above.
player_props_schedule_crons = [
  "cron(0 15 * * ? *)",
  "cron(30 15 * * ? *)",
  "cron(0 16 * * ? *)",
  "cron(30 16 * * ? *)",
  "cron(0 17 * * ? *)",
]

# Required for player-props Lambda. Use real values in terraform.tfvars.
# Optional: INCLUDE_TOMORROW=true to also fetch props for tomorrow's games (recommended so upcoming games get lines).
player_props_lambda_env = {
  BALLDONTLIE_API_KEY = "your_balldontlie_api_key"
  SUPABASE_DB_URL     = "postgresql://postgres.PROJECT:PASSWORD@REGION.pooler.supabase.com:6543/postgres"
  # INCLUDE_TOMORROW   = "true"
}
