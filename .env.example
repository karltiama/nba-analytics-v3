# Copy to `.env.local` for local Next.js development.
# Never commit real secrets. See docs/deployment-checklist.md for production.

# --- Next.js + Supabase (required for app/auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Postgres (API routes, scripts, AWS Lambdas) ---
# Use Supabase connection string; pooler often recommended for serverless.
SUPABASE_DB_URL=

# --- Vercel Cron (paper settlement) ---
# CRON_SECRET=
# PAPER_SETTLE_CRON_SECRET=

# --- Optional: AI routes (betting insights) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- BallDontLie + ingestion (scripts / Lambdas; not needed for UI-only local dev) ---
# BALLDONTLIE_API_KEY=
# Typo alias still read by some code paths:
# BALDONTLIE_API_KEY=
# BALLDONTLIE_REQUEST_DELAY_MS=200
# MAX_RETRIES=3
# PREFERRED_VENDOR=draftkings

# --- Optional: other scripts ---
# ODDS_API_KEY=
# AWS_REGION=us-east-1
